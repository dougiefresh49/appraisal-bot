{
  "manifest_version": 3,
  "name": "Deed Link Enhancer",
  "version": "1.1",
  "description": "Turns the 'Last Sale Instrument' field into a clickable link.",
  "permissions": ["cookies", "webNavigation"],
  "host_permissions": ["https://ectorcountytx-web.tylerhost.net/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://search.ectorcad.org/parcel/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
