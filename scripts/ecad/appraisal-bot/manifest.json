{
  "manifest_version": 3,
  "name": "AppraisalBot Linker",
  "author": "AppraisalBot",
  "version": "1.9.6",
  "description": "Turns the 'Last Sale Instrument' field into a clickable link and adds MLS Tax ID links.",
  "icons": {
    "16": "logos/logo16.png",
    "48": "logos/logo48.png",
    "128": "logos/logo128.png"
  },
  "action": {
    "default_icon": "logos/logo48.png",
    "default_popup": "popup/index.html"
  },
  "permissions": ["activeTab", "cookies", "webNavigation", "tabs"],
  "host_permissions": [
    "https://ectorcountytx-web.tylerhost.net/*",
    "https://search.ectorcad.org/*",
    "https://next.navicamls.net/*",
    "https://iswdataclient.azurewebsites.net/webProperty.aspx*",
    "https://maps.midlandtexas.gov/portal/apps/webappviewer/index.html?id=3cce4985d5f94f1c8c5d0ea06e1e5b47*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://search.ectorcad.org/parcel/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://ectorcountytx-web.tylerhost.net/web/search/DOCSEARCH144S1*"
      ],
      "js": ["search-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://next.navicamls.net/377/*"],
      "js": ["mls-injector-obr.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://next.navicamls.net/381/*"],
      "js": ["mls-injector-pbbr.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://iswdataclient.azurewebsites.net/webProperty.aspx*"],
      "js": ["mcad-deed-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://pbbr.crsdata.com/mls/property/*"],
      "js": ["mls-tax-suite-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://maps.midlandtexas.gov/portal/apps/webappviewer/index.html?id=3cce4985d5f94f1c8c5d0ea06e1e5b47*"
      ],
      "js": ["gis-injector-midland.js"],
      "run_at": "document_end"
    }
  ]
}
