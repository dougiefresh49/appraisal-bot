{
  "manifest_version": 3,
  "name": "AppraisalBot Linker",
  "author": "AppraisalBot",
  "version": "1.13.0",
  "description": "Appraisal workflow automation for West Texas. Links CAD, MLS, Deeds, and GIS sites together. Quick search across Andrews, Ector, Midland, Upton, and Ward counties. Navica MLS tools for search criteria, reports, and comp management.",
  "key": "",
  "icons": {
    "16": "logos/logo16.png",
    "48": "logos/logo48.png",
    "128": "logos/logo128.png"
  },
  "action": {
    "default_icon": "logos/logo48.png"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "permissions": [
    "activeTab",
    "cookies",
    "webNavigation",
    "storage",
    "tabs",
    "fileSystem",
    "scripting",
    "webRequest",
    "contextMenus",
    "sidePanel",
    "debugger",
    "downloads"
  ],
  "host_permissions": [
    "https://ectorcountytx-web.tylerhost.net/*",
    "https://search.ectorcad.org/*",
    "https://next.navicamls.net/*",
    "https://www.southwestdatasolution.com/webProperty.aspx*",
    "https://maps.midlandtexas.gov/portal/apps/webappviewer/index.html?id=3cce4985d5f94f1c8c5d0ea06e1e5b47*",
    "maps.midlandtexas.gov/*",
    "https://midland.tx.publicsearch.us/*",
    "https://www.wardcad.org/home/map*",
    "https://esearch.andrewscad.org/*",
    "https://andrewscountytx-web.tylerhost.net/*",
    "https://gis.bisclient.com/andrewscad/*",
    "file://*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["logos/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://search.ectorcad.org/parcel/*"],
      "js": ["ecad-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://ectorcountytx-web.tylerhost.net/web/*"],
      "js": ["ecad-deed-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://next.navicamls.net/377/*"],
      "js": ["navica-tools.js", "mls-injector-obr.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://next.navicamls.net/377/Mapping/GoogleMapSearch*"],
      "js": ["navica-map-tools.js", "mls-map-search-obr.js"],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://next.navicamls.net/377/*",
        "https://next.navicamls.net/381/*"
      ],
      "js": ["navica-map-tools.js", "mls-map-dialog-overlay.js"],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "matches": ["https://next.navicamls.net/381/*"],
      "js": ["navica-tools.js", "mls-injector-pbbr.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://www.southwestdatasolution.com/webProperty.aspx*"],
      "js": ["mcad-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://pbbr.crsdata.com/mls/property/*"],
      "js": ["mls-tax-suite-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://maps.midlandtexas.gov/*"],
      "js": [
        "gis-injector-midland--search.js",
        "gis-injector-midland--popup.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "matches": [
        "https://www.arcgis.com/apps/webappviewer/index.html?id=0264ff5463fa42a6b7ead58e42a46541*"
      ],
      "js": ["zoning-injector-ector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://midland.tx.publicsearch.us/results*"],
      "js": ["mcad-deed-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://i2j.uslandrecords.com/TX/Upton/D/default.aspx*"],
      "js": ["upton-deed-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://maps.pandai.com/WardCAD/*"],
      "js": ["gis-injector-ward--search.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://search.ectorcad.org/search/adv*"],
      "js": ["ecad-sale-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://esearch.andrewscad.org/Property/View/*"],
      "js": ["andrews-cad-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://andrewscountytx-web.tylerhost.net/web/*"],
      "js": ["andrews-deed-injector.js", "andrews-deed-search-injector.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://gis.bisclient.com/andrewscad/*"],
      "js": ["andrews-gis-injector.js"],
      "run_at": "document_end"
    }
  ]
}
